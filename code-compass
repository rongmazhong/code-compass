# 顶层目录的简易树形展示
_tree() {
  local lines=""
  local d
  [ -d "$TARGET_DIR" ] || return 0
  for d in "$TARGET_DIR"/*/; do
    [ -d "$d" ] && lines="${lines}├── $(basename "$d")/"$'\n'
  done
  # 顶层文件
  local f
  for f in "$TARGET_DIR"/*; do
    [ -f "$f" ] && lines="${lines}├── $(basename "$f")"$'\n'
  done
  printf '%s' "$lines"
}

# 模块表格行（基于探测到的顶层目录推断）
_module_rows() {
  local rows=""
  local d
  for d in "$TARGET_DIR"/*/; do
    [ -d "$d" ] || continue
    local name; name="$(basename "$d")"
    local role="（待补充职责）"
    case "$name" in
      src|lib|app) role="源码实现" ;;
      tests|test|spec) role="测试代码" ;;
      docs|doc) role="文档" ;;
      scripts|bin|tools) role="脚本与工具" ;;
      configs|conf|etc|config) role="配置" ;;
      deploy|infra|k8s) role="部署与基础设施" ;;
    esac
    rows="${rows}| $name/ | $role | （待补充） |"$'\n'
  done
  [ -z "$rows" ] && rows="| （未识别到顶层目录） | | |"
  printf '%s' "$rows"
}

# ---------------------------------------------------------------------------
# 工具函数
# ---------------------------------------------------------------------------
_set_stage() {
  local slug="$1" stage="$2"
  local state="$TARGET_DIR/.harness/state/workflow-state.json"
  [ -f "$state" ] || cmd_init >/dev/null 2>&1
  local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$state" "$stage" "$slug" "$ts" <<'PY'
import json, sys
path, stage, slug, ts = sys.argv[1:5]
try:
    data = json.load(open(path))
except Exception:
    data = {}
data["stage"] = stage
data["spec"] = slug
data["updated_at"] = ts
if stage not in data.get("completed", []):
    data.setdefault("completed", []).append(stage)
json.dump(data, open(path, "w"), indent=2, ensure_ascii=False)
print(open(path).read())
PY
  else
    warn "未找到 python3，跳过状态更新（请手动编辑 $state）"
  fi
}

cmd_help() {
  cat <<EOF
code-compass —— 个人 skill 库 CLI

用法:
  code-compass use-code-compass   注册并启用本 skill 库
  code-compass init               在当前项目初始化 .harness/ 与 AGENTS.md
  code-compass product-analysis [name]  柏拉图式发问，确定需求范围并生成 spec
  code-compass dev|develop [name] 基于 spec 进行开发实现
  code-compass wiki [topic]       更新/重建项目 wiki（docs/）
  code-compass help               显示本帮助

 环境变量:
   CODE_COMPASS_SKILLS_DIR   agent 技能目录 (默认 ~/.agents/skills)
   CODE_COMPASS_TARGET_DIR   目标项目目录   (默认 当前目录)
EOF
}

case "$cmd" in
  use|use-code-compass) cmd_use "$@" ;;
  init)                  cmd_init "$@" ;;
  product-analysis)      cmd_product_analysis "$@" ;;
  dev|develop)           cmd_dev "$@" ;;
  wiki)                  cmd_wiki "$@" ;;
  help|--help|-h)        cmd_help ;;
  *)                     warn "未知命令: $cmd"; cmd_help; exit 1 ;;
esac
