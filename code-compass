#!/usr/bin/env bash
# code-compass —— 个人 skill 库 CLI
#
# 设计融合了四种方法论：
#   - superpowers : 方法论优先（brainstorm / TDD / 系统化调试 / 计划驱动）
#   - gstack      : 角色化虚拟团队与发布流水线
#   - openspec    : spec 驱动的变更管理（specs / changes / tasks）
#   - develop-workflow-rong : 自动状态机编排（.harness/workflow-state.json）
#
# 本 CLI 是一个"调度器 + 脚手架"：它准备目录与状态文件，并指示 agent
# 读取对应 skills/<cmd>/SKILL.md 中的方法论去执行具体工作。
#
# 子命令：
#   use-code-compass   注册并启用本 skill 库（链接 skills 到 agent 的技能目录）
#   init               在当前项目初始化 .harness/ 与 AGENTS.md
#   design             进入柏拉图式发问，确定需求范围并生成 spec
#   dev|develop        基于 spec 进行开发实现
#   help               显示帮助

set -euo pipefail

CC_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_DIR="${CODE_COMPASS_SKILLS_DIR:-$HOME/.agents/skills}"
TARGET_DIR="${CODE_COMPASS_TARGET_DIR:-$(pwd)}"
MARKER_BEGIN="# >>> code-compass >>>"
MARKER_END="# <<< code-compass <<<"

cmd="${1:-help}"
shift || true

log()  { printf '\033[36m[code-compass]\033[0m %s\n' "$*"; }
warn() { printf '\033[33m[code-compass]\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[31m[code-compass]\033[0m %s\n' "$*" >&2; exit 1; }

# ---------------------------------------------------------------------------
# use-code-compass : 注册并启用 skill 库
# ---------------------------------------------------------------------------
cmd_use() {
  log "正在将 skills 链接到 agent 技能目录: $SKILLS_DIR"
  mkdir -p "$SKILLS_DIR"
  local count=0
  for d in "$CC_ROOT"/skills/*/; do
    name="$(basename "$d")"
    ln -sfn "$d" "$SKILLS_DIR/$name"
    count=$((count + 1))
  done
  log "已链接 $count 个 skill 到 $SKILLS_DIR"
  log "可用 skill: $(ls "$CC_ROOT"/skills)"

  # 确保当前项目已初始化 harness
  if [ ! -d "$TARGET_DIR/.harness" ]; then
    log "目标项目尚未初始化，先执行 init ..."
    cmd_init
  fi

  cat <<EOF

✅ code-compass 已启用。

agent 现在可以通过以下方式触发 skill：
  - 直接运行:  code-compass init | design | dev
  - agent skill 工具: 加载 skills/<name>/SKILL.md（已软链到 $SKILLS_DIR）

各 skill 触发条件见对应 SKILL.md 的 frontmatter description。
EOF
}

# ---------------------------------------------------------------------------
# init : 在当前项目初始化 .harness/ 与 AGENTS.md
# ---------------------------------------------------------------------------
cmd_init() {
  local harness="$TARGET_DIR/.harness"
  local state_dir="$harness/state"
  local rules_dir="$harness/rules"
  mkdir -p "$state_dir" "$rules_dir"

  # 写入 harness 配置
  if [ ! -f "$harness/config.json" ]; then
    cp "$CC_ROOT/harness/config.json" "$harness/config.json"
  fi
  # 写入初始工作流状态
  if [ ! -f "$state_dir/workflow-state.json" ]; then
    local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    sed "s/__UPDATED_AT__/$ts/" "$CC_ROOT/harness/workflow-state.json" > "$state_dir/workflow-state.json"
  fi

  # 探测项目并生成 rules/ 规则文件
  _detect_project
  _gen_rules "$rules_dir"

  # openspec 骨架
  mkdir -p "$TARGET_DIR/openspec/specs" "$TARGET_DIR/openspec/changes"
  if [ ! -f "$TARGET_DIR/openspec/project.md" ]; then
    cp "$CC_ROOT/openspec/project.md" "$TARGET_DIR/openspec/project.md"
  fi

  # 注入 AGENTS.md 指引
  local agent_md="$TARGET_DIR/AGENTS.md"
  local block; block="$(cat "$CC_ROOT/harness/AGENTS.md.harness")"
  if [ ! -f "$agent_md" ]; then
    printf '%s\n%s\n%s\n' "$MARKER_BEGIN" "$block" "$MARKER_END" > "$agent_md"
    log "已创建 $agent_md"
  elif grep -q "$MARKER_BEGIN" "$agent_md"; then
    warn "$agent_md 已包含 code-compass 段，跳过注入"
  else
    printf '\n%s\n%s\n%s\n' "$MARKER_BEGIN" "$block" "$MARKER_END" >> "$agent_md"
    log "已向 $agent_md 追加 code-compass 段"
  fi

  log "初始化完成："
  log "  .harness/config.json"
  log "  .harness/state/workflow-state.json"
  log "  .harness/rules/ (structure.md workflow.md coding.md)"
  log "  openspec/ (specs/ changes/ project.md)"
  log "  AGENTS.md (已注入 code-compass 路由)"
}

# ---------------------------------------------------------------------------
# design : 柏拉图式发问 -> 需求范围 -> spec 文档
# ---------------------------------------------------------------------------
cmd_design() {
  local name="${1:-}"
  [ -z "$name" ] && read -r -p "请输入本次变更名称 (kebab-case): " name
  [ -z "$name" ] && die "变更名称不能为空"
  local slug; slug="$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | sed 's/[^a-z0-9-]//g')"
  [ -z "$slug" ] && die "无法从 '$name' 生成合法 slug"

  local change_dir="$TARGET_DIR/openspec/changes/$slug"
  mkdir -p "$change_dir/specs"

  cp "$CC_ROOT/templates/proposal.md" "$change_dir/proposal.md"
  cp "$CC_ROOT/templates/tasks.md"   "$change_dir/tasks.md"

  # 更新工作流状态
  _set_stage "$slug" "design"

  cat <<EOF

✅ 已创建变更工作区: openspec/changes/$slug/
   - proposal.md  (为什么做)
   - tasks.md     (实现步骤)
   - specs/       (能力 spec delta，待 design 阶段填充)

下一步：请 agent 加载 skills/design/SKILL.md，按"柏拉图式发问"流程
与用户确认需求范围，并将结论写入上述文件。完成后运行:
   code-compass dev $slug
EOF
}

# ---------------------------------------------------------------------------
# dev|develop : 基于 spec 进行开发实现
# ---------------------------------------------------------------------------
cmd_dev() {
  local slug="${1:-}"
  if [ -z "$slug" ]; then
    local latest; latest="$(ls -1 "$TARGET_DIR/openspec/changes" 2>/dev/null | tail -1)"
    [ -z "$latest" ] && die "未找到任何变更，请先运行: code-compass design <name>"
    slug="$latest"
    warn "未指定变更，自动选择最新一个: $slug"
  fi
  local change_dir="$TARGET_DIR/openspec/changes/$slug"
  [ -d "$change_dir" ] || die "变更不存在: $slug"

  _set_stage "$slug" "dev"

  cat <<EOF

✅ 进入开发阶段: openspec/changes/$slug/
下一步：请 agent 加载 skills/dev/SKILL.md，按其中的方法论：
   1. writing-plans   将 spec 拆解为可执行的微任务
   2. TDD             红-绿-重构循环
   3. subagent        逐任务实现
   4. verification     完成前验证
EOF
}

# ---------------------------------------------------------------------------
# 项目探测：读取目标项目特征，供 rules/ 生成使用
# ---------------------------------------------------------------------------
_detect_project() {
  PROJ_LANG="未知"
  PROJ_TECH=""
  PROJ_BUILD=""
  PROJ_TEST=""
  PROJ_LINT=""
  PROJ_FMT=""
  PROJ_DIRS=""

  local d
  for d in "$TARGET_DIR"/*/; do
    [ -d "$d" ] && PROJ_DIRS="${PROJ_DIRS:+$PROJ_DIRS, }$(basename "$d")"
  done

  if [ -f "$TARGET_DIR/go.mod" ]; then
    PROJ_LANG="Go"; PROJ_TECH="Go 模块"
    command -v go >/dev/null 2>&1 && PROJ_BUILD="go build ./...  /  go run"
    PROJ_TEST="go test ./..."
    PROJ_LINT="go vet / golangci-lint"
    PROJ_FMT="gofmt / goimports"
  elif [ -f "$TARGET_DIR/Cargo.toml" ]; then
    PROJ_LANG="Rust"; PROJ_TECH="Cargo 项目"
    PROJ_BUILD="cargo build"
    PROJ_TEST="cargo test"
    PROJ_LINT="cargo clippy"
    PROJ_FMT="cargo fmt"
  elif [ -f "$TARGET_DIR/package.json" ]; then
    PROJ_LANG="JavaScript/TypeScript"; PROJ_TECH="Node.js 项目"
    if [ -f "$TARGET_DIR/tsconfig.json" ]; then PROJ_TECH="$PROJ_TECH (TypeScript)"; fi
    local scripts; scripts="$(grep -oE '"(build|test|lint|format|dev|start)"' "$TARGET_DIR/package.json" 2>/dev/null | tr -d '"' | tr '\n' ' ')"
    PROJ_BUILD="npm run build ${scripts:+($scripts)}"
    PROJ_TEST="npm test"
    PROJ_LINT="npm run lint / eslint"
    PROJ_FMT="npm run format / prettier"
    # 探测框架
    grep -q '"next"' "$TARGET_DIR/package.json" && PROJ_TECH="$PROJ_TECH, Next.js"
    grep -q '"react"' "$TARGET_DIR/package.json" && PROJ_TECH="$PROJ_TECH, React"
    true
  elif [ -f "$TARGET_DIR/pyproject.toml" ] || [ -f "$TARGET_DIR/requirements.txt" ]; then
    PROJ_LANG="Python"; PROJ_TECH="Python 项目"
    PROJ_BUILD="pip install -e ."
    PROJ_TEST="pytest"
    PROJ_LINT="ruff / pylint"
    PROJ_FMT="black / ruff format"
  elif [ -f "$TARGET_DIR/pom.xml" ] || [ -f "$TARGET_DIR/build.gradle" ]; then
    PROJ_LANG="Java/Kotlin"; PROJ_TECH="JVM 项目"
    PROJ_BUILD="mvn package / gradle build"
    PROJ_TEST="mvn test / gradle test"
    PROJ_LINT="spotless / checkstyle"
  elif [ -f "$TARGET_DIR/Gemfile" ]; then
    PROJ_LANG="Ruby"; PROJ_TECH="Ruby 项目"
    PROJ_BUILD="bundle exec rake"
    PROJ_TEST="bundle exec rspec"
  fi

  [ -z "$PROJ_TECH" ] && PROJ_TECH="（未在根目录识别到已知构建系统）"
  return 0
}

# ---------------------------------------------------------------------------
# 生成 rules/ 下的三个规则文件
# ---------------------------------------------------------------------------
_gen_rules() {
  local rules_dir="$1"

  # 1) 项目工程结构定义
  if [ ! -f "$rules_dir/structure.md" ]; then
    cat > "$rules_dir/structure.md" <<EOF
# 项目工程结构定义

> 由 \`code-compass init\` 探测生成，请按需补充与修正。

## 识别到的技术栈

- 语言：$PROJ_LANG
- 构建系统：$PROJ_TECH
- 顶层目录：${PROJ_DIRS:-（无）}

## 目录职责（推断）

| 目录 | 职责 |
|------|------|
$(_dir_roles)

## 约定

- 源码放置：根据上述目录职责统一管理
- 测试与源码同仓，按对应测试框架组织
- 文档、配置、脚本各自归位，避免散落根目录
EOF
    log "已生成 $rules_dir/structure.md"
  else
    warn "$rules_dir/structure.md 已存在，跳过"
  fi

  # 2) 开发流程
  if [ ! -f "$rules_dir/workflow.md" ]; then
    cat > "$rules_dir/workflow.md" <<EOF
# 开发流程

> 由 \`code-compass init\` 生成，结合 code-compass 方法论。

## 标准工作流（code-compass 驱动）

\`\`\`
idea → design → planned → dev → implemented → qa → verified → reviewed → shipped
\`\`\`

1. **design**：运行 \`code-compass design <name>\`，柏拉图式发问确定需求范围，
   产出 \`openspec/changes/<slug>/{proposal.md,tasks.md,specs/}\`。
2. **dev**：运行 \`code-compass dev <name>\`，按 spec 进行
   计划拆解 → TDD（红-绿-重构）→ 子代理实现 → 验证。
3. 每阶段切换都更新 \`.harness/state/workflow-state.json\`，中断可断点续跑。

## 构建 / 测试 / 检查命令（探测所得）

- 构建：${PROJ_BUILD:-（未识别，请补充）}
- 测试：${PROJ_TEST:-（未识别，请补充）}
- 静态检查：${PROJ_LINT:-（未识别，请补充）}
- 格式化：${PROJ_FMT:-（未识别，请补充）}

## 分支与提交

- 每个变更建议独立分支，命名与 \`openspec/changes/<slug>\` 对应
- 提交信息清晰描述"为什么"，而非仅"改了什么"
EOF
    log "已生成 $rules_dir/workflow.md"
  else
    warn "$rules_dir/workflow.md 已存在，跳过"
  fi

  # 3) 编码约束
  if [ ! -f "$rules_dir/coding.md" ]; then
    cat > "$rules_dir/coding.md" <<EOF
# 编码约束

> 由 \`code-compass init\` 探测生成，按技术栈裁剪。

## 通用原则

- 先理解问题再写代码；新增功能先写失败测试（TDD）
- 单一职责，函数/模块小而专注
- 错误信息要可操作，禁止静默吞掉异常
- 不引入未经确认的外部依赖；新增依赖前确认项目已在使用
- 不提交密钥、token 等敏感信息

## 语言相关约束（$PROJ_LANG）

$(_coding_rules)

## 风格

- 格式化工具：${PROJ_FMT:-（未识别）}
- 静态检查：${PROJ_LINT:-（未识别）}
- 命名、注释遵循社区主流约定（变量/函数小驼峰或 snake_case，类型/类大驼峰）
EOF
    log "已生成 $rules_dir/coding.md"
  else
    warn "$rules_dir/coding.md 已存在，跳过"
  fi
}

# 根据顶层目录推断职责
_dir_roles() {
  local rows=""
  _has src lib app      && rows="${rows}| src/ lib/ app/ | 源码实现 |"$'\n'
  _has tests test spec  && rows="${rows}| tests/ test/ spec/ | 测试代码 |"$'\n'
  _has docs doc         && rows="${rows}| docs/ doc/ | 文档 |"$'\n'
  _has scripts bin tools && rows="${rows}| scripts/ bin/ tools/ | 脚本与工具 |"$'\n'
  _has configs conf etc config && rows="${rows}| configs/ conf/ etc/ config/ | 配置 |"$'\n'
  _has deploy infra k8s && rows="${rows}| deploy/ infra/ k8s/ | 部署与基础设施 |"$'\n'
  [ -z "$rows" ] && rows="| （未识别到已知目录，请手动补充） | |"
  printf '%s' "$rows"
}
_has() {
  local want
  local dirs="${PROJ_DIRS// /}"
  for want in "$@"; do
    case ",$dirs," in *",$want,"*) return 0 ;; esac
  done
  return 1
}

# 语言特定的编码约束片段
_coding_rules() {
  case "$PROJ_LANG" in
    Go) cat <<'GO'
- 使用 \`gofmt\` 格式化，导出标识符写注释
- 错误处理显式返回，不忽略 error
- 包名简洁小写，避免下划线
GO
      ;;
    Rust) cat <<'RS'
- 优先 \`cargo fmt\` / \`cargo clippy\`
- 用 \`Result\` 表达可失败，避免 panic 于库代码
- 模块与 trait 组织清晰，避免过大 impl 块
RS
      ;;
    JavaScript/TypeScript) cat <<'JS'
- TypeScript 优先显式类型，避免 \`any\`
- 组件/函数单一职责，遵循项目既有框架约定
- 优先已有库（React/Next 等），不重复造轮子
JS
      ;;
    Python) cat <<'PY'
- 遵循 PEP 8，用 black/ruff 格式化
- 类型注解优先（函数签名标注类型）
- 用虚拟环境隔离依赖，依赖写入 pyproject/requirements
PY
      ;;
    *) echo "- （未识别语言，请补充对应约定）" ;;
  esac
}

# ---------------------------------------------------------------------------
# 工具函数
# ---------------------------------------------------------------------------
_set_stage() {
  local slug="$1" stage="$2"
  local state="$TARGET_DIR/.harness/state/workflow-state.json"
  [ -f "$state" ] || cmd_init >/dev/null 2>&1
  local ts; ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$state" "$stage" "$slug" "$ts" <<'PY'
import json, sys
path, stage, slug, ts = sys.argv[1:5]
try:
    data = json.load(open(path))
except Exception:
    data = {}
data["stage"] = stage
data["spec"] = slug
data["updated_at"] = ts
if stage not in data.get("completed", []):
    data.setdefault("completed", []).append(stage)
json.dump(data, open(path, "w"), indent=2, ensure_ascii=False)
print(open(path).read())
PY
  else
    warn "未找到 python3，跳过状态更新（请手动编辑 $state）"
  fi
}

cmd_help() {
  cat <<EOF
code-compass —— 个人 skill 库 CLI

用法:
  code-compass use-code-compass   注册并启用本 skill 库
  code-compass init               在当前项目初始化 .harness/ 与 AGENTS.md
  code-compass design [name]      柏拉图式发问，确定需求范围并生成 spec
  code-compass dev|develop [name] 基于 spec 进行开发实现
  code-compass help               显示本帮助

环境变量:
  CODE_COMPASS_SKILLS_DIR   agent 技能目录 (默认 ~/.agents/skills)
  CODE_COMPASS_TARGET_DIR   目标项目目录   (默认 当前目录)
EOF
}

case "$cmd" in
  use|use-code-compass) cmd_use "$@" ;;
  init)                  cmd_init "$@" ;;
  design)                cmd_design "$@" ;;
  dev|develop)           cmd_dev "$@" ;;
  help|--help|-h)        cmd_help ;;
  *)                     warn "未知命令: $cmd"; cmd_help; exit 1 ;;
esac
